# =========================
# CORE APPLICATION
# =========================
# URL API gateway Tips'yo (используется для CTA/форм связи)
VITE_API_BASE_URL=https://api.tipsyo.example

# Статический CDN для картинок/стилей
VITE_CDN_URL=https://static.tipsyo.example

# Название окружения: development | staging | production
VITE_APP_ENV=development

# =========================
# PAYMENTS (MIDTRANS + GOOGLE PAY)
# =========================
# Серверные ключи Midtrans (Snap/Payment Link/Core API)
MIDTRANS_SERVER_KEY=midtrans_server_key
MIDTRANS_CLIENT_KEY=midtrans_client_key
MIDTRANS_MERCHANT_ID=midtrans_merchant_id

# Окружение Midtrans: sandbox | production
MIDTRANS_ENV=sandbox

# Callback/notification подпись (используется в backend API)
MIDTRANS_NOTIFICATION_SECRET=midtrans_notification_secret

# Базовый URL для Payment Link (если формируем ссылки вручную)
MIDTRANS_PAYMENT_LINK_BASE_URL=https://link.midtrans.com/tipsyo

# Google Pay sandbox merchant ID (для тестов Snap)
GOOGLE_PAY_TEST_MERCHANT_ID=BCR2DN4TIPSYO

# =========================
# ANALYTICS & MONITORING
# =========================
# Идентификатор аналитики (например, Plausible/GA/Amplitude)
VITE_ANALYTICS_ID=plausible_site_id

# DSN для мониторинга ошибок (Sentry и т.п.)
VITE_SENTRY_DSN=https://public@sentry.example/project-id

# =========================
# MARKETING & SUPPORT
# =========================
# ID/токен чат-виджета (Intercom, Crisp, и т.д.)
VITE_SUPPORT_WIDGET_TOKEN=chat_token

# Контактная ссылка для CTA (WhatsApp/Telegram)
VITE_CONTACT_LINK=https://t.me/tipsyo_support
