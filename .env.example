# =========================
# CORE APPLICATION
# =========================
# URL API gateway Tips'yo (используется для CTA/форм связи)
VITE_API_BASE_URL=https://api.tipsyo.example

# Статический CDN для картинок/стилей
VITE_CDN_URL=https://static.tipsyo.example

# Название окружения: development | staging | production
VITE_APP_ENV=development

# =========================
# ANALYTICS & MONITORING
# =========================
# Идентификатор аналитики (например, Plausible/GA/Amplitude)
VITE_ANALYTICS_ID=plausible_site_id

# DSN для мониторинга ошибок (Sentry и т.п.)
VITE_SENTRY_DSN=https://public@sentry.example/project-id

# =========================
# MARKETING & SUPPORT
# =========================
# ID/токен чат-виджета (Intercom, Crisp, и т.д.)
VITE_SUPPORT_WIDGET_TOKEN=chat_token

# Контактная ссылка для CTA (WhatsApp/Telegram)
VITE_CONTACT_LINK=https://t.me/tipsyo_support
